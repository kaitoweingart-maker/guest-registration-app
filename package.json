{
  "name": "guest-registration-app",
  "version": "1.0.0",
  "description": "Gästeregistrierung / Guest Registration for Amanthos Living Hotels",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "render-build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "seed": "node server/database/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
